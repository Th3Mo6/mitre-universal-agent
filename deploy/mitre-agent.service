[Unit]
Description=Universal MITRE AI Agent — control panel
Documentation=file:/opt/mitre-agent/docs/Architecture.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=mitre
Group=mitre
WorkingDirectory=/opt/mitre-agent
EnvironmentFile=/etc/mitre-agent/agent.env
ExecStart=/opt/mitre-agent/venv/bin/python /opt/mitre-agent/app.py
Restart=on-failure
RestartSec=5

# --- hardening (read-only source access; the agent never deploys rules) ---
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/mitre-agent
ProtectKernelTunables=true
ProtectControlGroups=true
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=multi-user.target
